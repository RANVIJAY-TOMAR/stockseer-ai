            """, unsafe_allow_html=True)
            
            financials = {
                "Revenue (TTM)": f"{current_currency_symbol}{s_info_full.get('totalRevenue', 0):,.2f}" if s_info_full.get('totalRevenue') else 'N/A',
                "Profit Margin": f"{s_info_full.get('profitMargins', 0)*100:.2f}%" if s_info_full.get('profitMargins') else 'N/A',
                "Operating Margin": f"{s_info_full.get('operatingMargins', 0)*100:.2f}%" if s_info_full.get('operatingMargins') else 'N/A',
                "P/E Ratio": f"{s_info_full.get('trailingPE', 0):.2f}" if s_info_full.get('trailingPE') else 'N/A',
                "EPS (TTM)": f"{current_currency_symbol}{s_info_full.get('trailingEps', 0):.2f}" if s_info_full.get('trailingEps') else 'N/A',
                "Dividend Yield": f"{s_info_full.get('dividendYield', 0)*100:.2f}%" if s_info_full.get('dividendYield') else 'N/A',
                "Beta": f"{s_info_full.get('beta', 0):.2f}" if s_info_full.get('beta') else 'N/A'
            }
            
            for key, value in financials.items():
                st.markdown(f"**{key}:** {value}")

        # Company Officers
        if company_officers:
            st.markdown("""
                <div class="animated-card">
                    <h4 class="glow-text">👥 Key Executives</h4>
                </div>
            """, unsafe_allow_html=True)
            
            for officer in company_officers:
                st.markdown(f"""
                    <div class="animated-card" style="margin: 10px 0;">
                        <p><b>{officer.get('name', 'N/A')}</b><br>
                        Title: {officer.get('title', 'N/A')}<br>
                        {f"Age: {officer.get('age')}" if officer.get('age') else ''}</p>
                    </div>
                """, unsafe_allow_html=True)

        # Analyst Recommendations
        if analyst_recs is not None and not analyst_recs.empty:
            st.markdown("""
                <div class="animated-card">
                    <h4 class="glow-text">📈 Analyst Coverage</h4>
                </div>
            """, unsafe_allow_html=True)
            
            latest_recs = analyst_recs.tail(5)
            for _, rec in latest_recs.iterrows():
                date_str = rec.name.strftime('%Y-%m-%d') if hasattr(rec.name, 'strftime') else str(rec.name)
                st.markdown(f"""
                    <div class="animated-card" style="margin: 10px 0;">
                        <p><b>{rec.get('Firm', 'N/A')}</b><br>
                        Grade: {rec.get('To Grade', 'N/A')}<br>
                        Date: {date_str}</p>
                    </div>
                """, unsafe_allow_html=True)

        # Price Targets
        if s_info_full and any([s_info_full.get('targetMeanPrice'), s_info_full.get('targetHighPrice'), s_info_full.get('targetLowPrice')]):
            st.markdown("""
                <div class="animated-card">
                    <h4 class="glow-text">🎯 Analyst Price Targets</h4>
                </div>
            """, unsafe_allow_html=True)
            
            targets_col1, targets_col2, targets_col3 = st.columns(3)
            with targets_col1:
                st.metric("Low Target", f"{current_currency_symbol}{s_info_full.get('targetLowPrice', 'N/A')}")
            with targets_col2:
                st.metric("Mean Target", f"{current_currency_symbol}{s_info_full.get('targetMeanPrice', 'N/A')}")
            with targets_col3:
                st.metric("High Target", f"{current_currency_symbol}{s_info_full.get('targetHighPrice', 'N/A')}")

        # Institutional Ownership
        st.markdown("""
            <div class="animated-card">
                <h4 class="glow-text">🏛️ Ownership Structure</h4>
            </div>
        """, unsafe_allow_html=True)
        
        ownership_col1, ownership_col2 = st.columns(2)
        with ownership_col1:
            inst_own = s_info_full.get('institutionOwnership', 0)
            if inst_own:
                st.metric("Institutional Ownership", f"{inst_own*100:.2f}%")
            insider_own = s_info_full.get('insiderOwnership', 0)
            if insider_own:
                st.metric("Insider Ownership", f"{insider_own*100:.2f}%")
        
        with ownership_col2:
            shares_short = s_info_full.get('sharesShort', 0)
            shares_out = s_info_full.get('sharesOutstanding', 0)
            if shares_short and shares_out:
                short_ratio = (shares_short / shares_out) * 100
                st.metric("Short Interest", f"{short_ratio:.2f}%")
            float_shares = s_info_full.get('floatShares', 0)
            if float_shares:
                st.metric("Float Shares", f"{float_shares:,}")