            },
            "China": {
                "A-Shares": "8-12%",
                "Mutual Funds": "7-10%",
                "Bonds": "3-5%",
                "Bank Deposits": "2-3%",
                "REITs": "5-7%"
            }
        }

        # Display country-specific investment options
        st.markdown(f"""
            <div class="animated-card">
                <h4 class="glow-text">📈 {selected_country} Investment Options</h4>
                <p>Typical returns in {selected_country} market:</p>
            </div>
        """, unsafe_allow_html=True)

        for option, returns in country_investment_options.get(selected_country, country_investment_options["United States"]).items():
            st.markdown(f"- **{option}:** {returns} typical annual returns")
        
        # Risk Profile
        st.markdown("""
            <div class="animated-card">
                <h4 class="glow-text">🎲 Risk Profile</h4>
            </div>
        """, unsafe_allow_html=True)
        
        risk_profile = st.select_slider(
            "Select your risk tolerance",
            options=["Conservative", "Moderately Conservative", "Moderate", "Moderately Aggressive", "Aggressive"],
            value="Moderate"
        )
        
        # Calculate button
        if st.button("Calculate Plan", use_container_width=True):
            try:
                # Time period in years
                time_period = target_age - current_age
                
                # Calculate future value needed (accounting for inflation)
                future_value = target_amount * (1 + inflation_rate/100) ** time_period
                
                # Expected returns based on risk profile
                expected_returns = {
                    "Conservative": 6.0,
                    "Moderately Conservative": 8.0,
                    "Moderate": 10.0,
                    "Moderately Aggressive": 12.0,
                    "Aggressive": 14.0
                }
                
                return_rate = expected_returns[risk_profile]
                
                # Calculate required monthly investment
                r = return_rate/100/12  # Monthly rate
                n = time_period * 12    # Number of months
                
                # Using numpy financial for PMT calculation
                required_monthly = -npf.pmt(r, n, -current_savings, future_value)
                
                # Display Results
                st.markdown("""
                    <div class="animated-card">
                        <h4 class="glow-text">📊 Financial Plan Results</h4>
                    </div>
                """, unsafe_allow_html=True)
                
                result_cols = st.columns(2)
                with result_cols[0]:
                    st.metric("Future Value Needed", f"{current_currency_symbol}{future_value:,.2f}")
                    st.metric("Current Gap", f"{current_currency_symbol}{(future_value - current_savings):,.2f}")
                    
                with result_cols[1]:
                    st.metric("Required Monthly Investment", f"{current_currency_symbol}{required_monthly:,.2f}")
                    st.metric("Your Current Monthly Investment", f"{current_currency_symbol}{monthly_investment:,.2f}")
                
                # Portfolio Allocation
                st.markdown("""
                    <div class="animated-card">
                        <h4 class="glow-text">📈 Recommended Portfolio Allocation</h4>
                    </div>
                """, unsafe_allow_html=True)
                
                # Portfolio allocation based on risk profile
                allocations = {
                    "Conservative": {"Stocks": 30, "Bonds": 50, "Cash": 20},
                    "Moderately Conservative": {"Stocks": 45, "Bonds": 40, "Cash": 15},
                    "Moderate": {"Stocks": 60, "Bonds": 30, "Cash": 10},
                    "Moderately Aggressive": {"Stocks": 75, "Bonds": 20, "Cash": 5},
                    "Aggressive": {"Stocks": 85, "Bonds": 10, "Cash": 5}
                }
                
                current_allocation = allocations[risk_profile]
                
                # Create allocation chart
                fig = px.pie(
                    values=list(current_allocation.values()),
                    names=list(current_allocation.keys()),
                    title="Recommended Portfolio Allocation",
                    color_discrete_sequence=px.colors.qualitative.Set3
                )
                fig.update_layout(
                    showlegend=True,
                    plot_bgcolor="rgba(0,0,0,0)",
                    paper_bgcolor="rgba(0,0,0,0)",
                    font=dict(color="#e0e0e0")
                )
                st.plotly_chart(fig, use_container_width=True)
                
                # Additional Recommendations
                st.markdown("""
                    <div class="animated-card">
                        <h4 class="glow-text">💡 Recommendations</h4>
                    </div>
                """, unsafe_allow_html=True)
                
                if monthly_investment < required_monthly:
                    st.warning(f"You need to increase your monthly investment by {current_currency_symbol}{required_monthly - monthly_investment:,.2f} to reach your goal.")
                else:
                    st.success("You're on track to reach your financial goal!")
                    
                # Investment suggestions based on risk profile
                st.markdown(f"""
                    <div style="padding: 20px; background: rgba(26,26,26,0.9); border-radius: 10px; margin: 10px 0;">
                        <h5 style="color: #39ff14;">Investment Suggestions:</h5>
                        <ul style="color: #e0e0e0;">
                            <li>Consider a portfolio with {current_allocation['Stocks']}% in stocks for long-term growth</li>
                            <li>Maintain {current_allocation['Bonds']}% in bonds for stability</li>
                            <li>Keep {current_allocation['Cash']}% in cash/liquid funds for emergencies</li>
                            <li>Review and rebalance your portfolio every 6 months</li>
                            <li>Consider consulting with a financial advisor for personalized advice</li>
                        </ul>
                    </div>
                """, unsafe_allow_html=True)
                
            except Exception as e:
                st.error(f"Error in calculations: {str(e)}")
                st.info("Please check your input values and try again.")

