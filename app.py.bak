# --- LOTTIE HELPER ---
@st.cache_data
def load_lottiefile(filepath: str):
    try:
        with open(filepath, "r") as f:
            return json.load(f)
    except FileNotFoundError:
        print(f"Lottie/Asset file not found: {filepath}")
        return None
    except json.JSONDecodeError:
        print(f"Error decoding Lottie JSON: {filepath}")
        return None

