                    "LIQUIDBEES.NS": "Liquid BeES"
                },
                "United Kingdom": {
                    "ISF.L": "FTSE 100",
                    "VMID.L": "FTSE 250",
                    "VUKE.L": "FTSE All-Share",
                    "VEUR.L": "European Stock",
