            target_age = st.number_input("Target Age/Year", min_value=current_age + 1, max_value=100, value=min(current_age + 10, 65))
            current_savings = st.number_input(f"Current Savings ({DEFAULT_CURRENCY_SYMBOL})", min_value=0, value=10000)
        
        with param_cols[1]:
            monthly_investment = st.number_input(f"Monthly Investment Capacity ({DEFAULT_CURRENCY_SYMBOL})", min_value=0, value=1000)
            target_amount = st.number_input(f"Target Amount ({DEFAULT_CURRENCY_SYMBOL})", min_value=0, value=100000)
            inflation_rate = st.slider(f"Expected Inflation Rate in {selected_country} (%)", 
                                    min_value=2.0, max_value=10.0, 
                                    value=6.0 if selected_country == "India" else 3.0,  # Higher default for India
                                    step=0.1)

        # Country-specific investment options
        country_investment_options = {
            "India": {
                "Fixed Deposit": "6.5%",
                "PPF": "7.1%",
                "NPS": "8-10%",
                "Mutual Funds": "12-15%",
                "Stocks": "15-18%"
            },
            "United States": {
